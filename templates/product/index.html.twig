{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">

        <div class="col-md-6">
            <div class="bg-light p-5 text-center rounded">
                <p class="text-muted">Product Image</p>
            </div>
        </div>

        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_home') }}" class="text-decoration-none">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Product Details</li>
                </ol>
            </nav>

            <span class="badge bg-primary mb-3">
                {{ product.category ? product.category.name : 'No Category' }}
            </span>
            <h1 class="mb-3">{{ product.name }}</h1>
            <h3 class="text-success mb-4">${{ product.price }}</h3>

            <div class="mb-4">
                <h5>Description</h5>
                <p class="text-muted">{{ product.description }}</p>
            </div>

            <form>
                <div class="mb-3">
                    <label for="quantity" class="form-label">Quantity</label>
                    <input type="number" class="form-control" id="quantity" 
                           value="1" min="1" max="{{ product.stock }}" 
                           style="max-width: 100px;">
                </div>
                <div class="d-grid gap-2 d-md-flex">
                    <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
                    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg">
                        Continue Shopping
                    </a>
                </div>
            </form>

            <div class="mt-4 pt-4 border-top">
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <strong>Availability:</strong>
                        {% if product.stock > 0 %}
                            <span class="text-success">In Stock ({{ product.stock }} left)</span>
                        {% else %}
                            <span class="text-danger">Out of Stock</span>
                        {% endif %}
                    </li>
                    <li class="mb-2">
                        <strong>Category:</strong>
                        {{ product.category ? product.category.name : 'N/A' }}
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
{% endblock %}